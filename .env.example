# Database
DATABASE_URL=postgresql+asyncpg://sierra:sierra@localhost:5432/sierraviva

# NASA FIRMS API
# Get your free API key at: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_API_KEY=your_firms_api_key_here

# Global Forest Watch API
# Sign up at: https://www.globalforestwatch.org/my-gfw/
# Then request an API key via the GFW Data API
GFW_API_KEY=

# Copernicus Data Space Ecosystem (Sentinel-2 imagery)
# Sign up free at: https://dataspace.copernicus.eu
CDSE_USERNAME=
CDSE_PASSWORD=

# Polling intervals (hours)
FIRMS_POLL_INTERVAL_HOURS=6
GFW_POLL_INTERVAL_HOURS=24

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
